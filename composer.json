{
    "name": "derrickob/gemini-api",
    "type": "library",
    "description": "A lightweight, efficient PHP client for seamless Google Gemini API integration.",
    "keywords": [
        "google",
        "generative-ai",
        "gemini-api",
        "api",
        "gemini",
        "gemini-client",
        "google-gemini",
        "php"
    ],
    "homepage": "https://github.com/derrickobedgiu1/gemini-api",
    "license": "MIT",
    "authors": [
        {
            "name": "Derrick Obedgiu",
            "email": "derrickobedgiu@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.8.0",
        "google/auth": "^1.37"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "friendsofphp/php-cs-fixer": "^3.54",
        "fakerphp/faker": "^1.23.1"
    },
    "autoload": {
        "psr-4": {
            "Derrickob\\GeminiApi\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Derrickob\\GeminiApi\\Tests\\": "tests"
        }
    },
    "scripts": {
        "unit-test": "vendor/bin/phpunit --group unit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}